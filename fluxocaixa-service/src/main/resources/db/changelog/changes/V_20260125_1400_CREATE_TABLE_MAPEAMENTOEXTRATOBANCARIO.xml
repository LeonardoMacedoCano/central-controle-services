<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">

    <changeSet id="create-table-mapeamentoextratobancario" author="lcano">
        <preConditions onFail="MARK_RAN" onFailMessage="A tabela mapeamentoextratobancario já existe">
            <not>
                <tableExists tableName="mapeamentoextratobancario"/>
            </not>
        </preConditions>

        <createTable tableName="mapeamentoextratobancario">
            <column name="id" type="${integer}" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pkmapeamentoextratobancario"/>
            </column>
            <column name="idusuario" type="${integer}">
                <constraints nullable="false"/>
            </column>
            <column name="tiporegra" type="${varchar_20}">
                <constraints nullable="false"/>
            </column>
            <column name="descricao" type="${varchar_255}">
                <constraints nullable="false"/>
            </column>
            <column name="descricaomatch" type="${varchar_255}">
                <constraints nullable="false"/>
            </column>
            <column name="descricaodestino" type="${varchar_255}"/>
            <column name="idcategoriadespesadestino" type="${integer}"/>
            <column name="idcategoriarendadestino" type="${integer}"/>
            <column name="idcategoriaativodestino" type="${integer}" />
            <column name="prioridade" type="${integer}" defaultValue="0">
                <constraints nullable="false"/>
            </column>
            <column name="ativo" type="${char_1}" defaultValue="S">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseTableName="mapeamentoextratobancario"
                                 baseColumnNames="idcategoriadespesadestino"
                                 constraintName="fkmapeamentoextratobancariocatdesp"
                                 referencedTableName="movimentacaocategoria"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="mapeamentoextratobancario"
                                 baseColumnNames="idcategoriarendadestino"
                                 constraintName="fkmapeamentoextratobancariocatren"
                                 referencedTableName="movimentacaocategoria"
                                 referencedColumnNames="id"/>

        <addForeignKeyConstraint baseTableName="mapeamentoextratobancario"
                                 baseColumnNames="idcategoriaativodestino"
                                 constraintName="fkmapeamentoextratobancariocatativo"
                                 referencedTableName="movimentacaocategoria"
                                 referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
